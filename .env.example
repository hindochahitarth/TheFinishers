# GreenPulse AI - Environment Configuration
# Copy this file to .env and fill in your values

# ══════════════════════════════════════════════════════════════════
# DATABASE CONFIGURATION
# ══════════════════════════════════════════════════════════════════
MYSQL_HOST=db
MYSQL_PORT=3306
MYSQL_USER=greenpulse
MYSQL_PASSWORD=greenpulse_secure_password
MYSQL_DATABASE=greenpulse_db
MYSQL_ROOT_PASSWORD=root_secure_password

# ══════════════════════════════════════════════════════════════════
# REDIS CACHE
# ══════════════════════════════════════════════════════════════════
REDIS_URL=redis://redis:6379

# ══════════════════════════════════════════════════════════════════
# EXTERNAL API KEYS
# Get these from the respective services. Without these, the system
# will use mock data for development/testing.
# ══════════════════════════════════════════════════════════════════

# OpenWeatherMap - Weather and basic air quality data
# Get free key at: https://openweathermap.org/api
OPENWEATHERMAP_API_KEY=

# OpenAQ - Air quality measurements (optional, free)
# Get key at: https://openaq.org
OPENAQ_API_KEY=your_openaq_api_key

# TomTom - Traffic data
# Get free key at: https://developer.tomtom.com
TOMTOM_API_KEY=

# ══════════════════════════════════════════════════════════════════
# LLM CONFIGURATION (OPTIONAL)
# Required for AI agent natural language capabilities.
# Without this, the system uses rule-based responses.
# ══════════════════════════════════════════════════════════════════

# LLM API Key - Choose ONE provider:
# - OpenAI: https://platform.openai.com
# - Anthropic: https://console.anthropic.com
# - Google: https://aistudio.google.com
LLM_API_KEY=

# LLM Model Selection
# OpenAI: gpt-4o, gpt-4o-mini, gpt-4-turbo
# Anthropic: claude-3-sonnet-20240229, claude-3-haiku-20240307
# Google: gemini-1.5-pro, gemini-1.5-flash
LLM_MODEL=gpt-4o-mini

# LLM Provider: openai, anthropic, or google
LLM_PROVIDER=openai

# ══════════════════════════════════════════════════════════════════
# APPLICATION SETTINGS
# ══════════════════════════════════════════════════════════════════

# Default monitoring location
DEFAULT_CITY=New Delhi
DEFAULT_COUNTRY_CODE=IN
DEFAULT_LAT=28.6139
DEFAULT_LON=77.2090

# Data refresh interval (seconds)
DATA_REFRESH_INTERVAL=300

# ══════════════════════════════════════════════════════════════════
# MODEL PATHS (Docker volumes)
# ══════════════════════════════════════════════════════════════════
MODEL_SAVE_PATH=/app/models
FORECAST_MODEL_PATH=/app/models/forecast
ANOMALY_MODEL_PATH=/app/models/anomaly

# ══════════════════════════════════════════════════════════════════
# FRONTEND CONFIG (for Next.js)
# ══════════════════════════════════════════════════════════════════
NEXT_PUBLIC_API_URL=http://localhost:8000

# ══════════════════════════════════════════════════════════════════
# OPTIONAL: MONITORING & LOGGING
# ══════════════════════════════════════════════════════════════════
# LOG_LEVEL=INFO
# ENABLE_METRICS=true
# SENTRY_DSN=your_sentry_dsn
